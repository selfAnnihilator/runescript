// Variable declarations with type annotations
let name: string = "Alice";
let age: int = 25;
let active: bool = true;

print("Name:   ", name);
print("Age:    ", age);
print("Active: ", active);

// Reassignment
age = age + 1;
print("Next year: ", age);

// Scoped block — x only exists inside the braces
{
    let x: int = 100;
    print("Inside block: ", x);
}
// x is gone here
