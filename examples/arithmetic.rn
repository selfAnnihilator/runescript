let a: int = 10;
let b: int = 3;

print("Addition:       ", a + b);   // 13
print("Subtraction:    ", a - b);   // 7
print("Multiplication: ", a * b);   // 30
print("Division:       ", a / b);   // 3  (integer division)

print("a > b:  ", a > b);    // true
print("a == b: ", a == b);   // false
print("a != b: ", a != b);   // true
print("a <= b: ", a <= b);   // false
